<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width={{WIDTH}}, height={{HEIGHT}}" />
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body {
        width: {{WIDTH}}px;
        height: {{HEIGHT}}px;
        overflow: hidden;
        background: #0b0e14;
        color: #f8fafc;
        font-family: "Inter", "Segoe UI", system-ui, sans-serif;
      }
      #root { position: relative; width: 100%; height: 100%; }

      /* ── shared slide base ── */
      .slide {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 6% 8%;
        opacity: 0;
      }

      /* ── cover ── */
      .slide-cover {
        background: linear-gradient(145deg, #0f172a 0%, #1e293b 100%);
        gap: 1.2em;
      }
      .slide-cover .cover-img {
        max-width: 40%;
        max-height: 35%;
        object-fit: contain;
        border-radius: 1vw;
        margin-bottom: 0.6em;
        opacity: 0.9;
      }
      .slide-cover .heading {
        font-size: 4.2vw;
        font-weight: 800;
        color: #7dd3fc;
        text-align: center;
        letter-spacing: 0.02em;
        line-height: 1.15;
      }
      .slide-cover .subheading {
        font-size: 2.2vw;
        font-weight: 400;
        color: #94a3b8;
        text-align: center;
      }

      /* ── body ── */
      .slide-body {
        background: #0b0e14;
        align-items: flex-start;
        padding: 6% 10%;
        gap: 1.4em;
      }
      .slide-body .heading {
        font-size: 2.2vw;
        font-weight: 700;
        color: #7dd3fc;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        border-bottom: 0.15vw solid #1e3a5f;
        padding-bottom: 0.4em;
        width: 100%;
      }
      .slide-body .body-text {
        font-size: 2.8vw;
        line-height: 1.45;
        color: #e2e8f0;
        font-weight: 400;
      }
      .slide-body .body-text strong, .slide-body .body-text b { color: #7dd3fc; font-weight: 700; }
      .slide-body .body-text em, .slide-body .body-text i { color: #a5f3fc; }
      .slide-body .speaker-note {
        font-size: 1.6vw;
        color: #64748b;
        font-style: italic;
        margin-top: auto;
        align-self: flex-end;
      }

      /* ── image_focus ── */
      .slide-image-focus { background: #060a10; }
      .slide-image-focus .focus-img {
        max-width: 90%;
        max-height: 78%;
        object-fit: contain;
        border-radius: 0.8vw;
        box-shadow: 0 1.5vw 4vw rgba(0, 0, 0, 0.7);
      }
      .slide-image-focus .caption {
        font-size: 1.8vw;
        color: #94a3b8;
        margin-top: 1.2em;
        text-align: center;
        max-width: 80%;
      }

      /* ── section divider ── */
      .slide-section {
        background: linear-gradient(135deg, #0f172a 0%, #0d1f38 100%);
      }
      .slide-section::before {
        content: "";
        position: absolute;
        left: 8%;
        right: 8%;
        top: 50%;
        height: 0.2vw;
        background: linear-gradient(90deg, transparent, #334155, transparent);
        transform: translateY(-2.5em);
      }
      .slide-section .title {
        font-size: 3.6vw;
        font-weight: 700;
        color: #f1f5f9;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-align: center;
      }

      /* ── outro ── */
      .slide-outro {
        background: linear-gradient(145deg, #0f172a 0%, #0d2744 100%);
        gap: 1em;
      }
      .slide-outro .outro-icon {
        font-size: 4vw;
        margin-bottom: 0.3em;
        opacity: 0.6;
      }
      .slide-outro .cta {
        font-size: 2.6vw;
        font-weight: 600;
        color: #7dd3fc;
        text-align: center;
        max-width: 80%;
        line-height: 1.3;
      }
    </style>
  </head>
  <body>
    <div
      id="root"
      data-composition-id="main"
      data-start="0"
      data-duration="{{DURATION}}"
      data-width="{{WIDTH}}"
      data-height="{{HEIGHT}}"
    ></div>

    <script id="trispr-scenes" type="application/json">{{SCENES_JSON}}</script>

    <script>
      (function () {
        var scenes = JSON.parse(document.getElementById("trispr-scenes").textContent || "[]");
        var root = document.getElementById("root");

        var durations = scenes.map(function (s) {
          if (s.type === "cover" || s.type === "outro") return 4.0;
          if (s.type === "section") return 2.5;
          if (s.type === "image_focus") return 5.0;
          // body: reading speed ~2.5 wps, min 4s max 12s
          var words = (s.body || "").replace(/<[^>]*>/g, "").split(/\s+/).filter(Boolean).length;
          return Math.min(12.0, Math.max(4.0, Math.ceil(words / 2.5)));
        });

        var fadeDur = 0.35;

        var tl = gsap.timeline({ paused: true });

        scenes.forEach(function (scene, idx) {
          var start = durations.slice(0, idx).reduce(function (a, b) { return a + b; }, 0);
          var dur = durations[idx];
          var slide = document.createElement("div");
          slide.className = "slide clip";
          slide.setAttribute("data-start", start.toString());
          slide.setAttribute("data-duration", dur.toString());
          slide.setAttribute("data-track-index", "1");

          switch (scene.type) {
            case "cover":
              slide.classList.add("slide-cover");
              if (scene.image_ref) {
                var img = document.createElement("img");
                img.className = "cover-img";
                img.src = scene.image_ref;
                img.alt = "";
                slide.appendChild(img);
              }
              var h = document.createElement("div");
              h.className = "heading";
              h.textContent = scene.heading || "";
              slide.appendChild(h);
              if (scene.subheading) {
                var sub = document.createElement("div");
                sub.className = "subheading";
                sub.textContent = scene.subheading;
                slide.appendChild(sub);
              }
              break;

            case "body":
              slide.classList.add("slide-body");
              var bh = document.createElement("div");
              bh.className = "heading";
              bh.textContent = scene.heading || "";
              slide.appendChild(bh);
              var bt = document.createElement("div");
              bt.className = "body-text";
              bt.innerHTML = scene.body || "";
              slide.appendChild(bt);
              if (scene.speaker_note) {
                var sn = document.createElement("div");
                sn.className = "speaker-note";
                sn.textContent = scene.speaker_note;
                slide.appendChild(sn);
              }
              break;

            case "image_focus":
              slide.classList.add("slide-image-focus");
              var fi = document.createElement("img");
              fi.className = "focus-img";
              fi.src = scene.image_ref || "";
              fi.alt = scene.caption || "";
              slide.appendChild(fi);
              if (scene.caption) {
                var fc = document.createElement("div");
                fc.className = "caption";
                fc.textContent = scene.caption;
                slide.appendChild(fc);
              }
              break;

            case "section":
              slide.classList.add("slide-section");
              var st = document.createElement("div");
              st.className = "title";
              st.textContent = scene.title || "";
              slide.appendChild(st);
              break;

            case "outro":
              slide.classList.add("slide-outro");
              var oi = document.createElement("div");
              oi.className = "outro-icon";
              oi.textContent = "✦";
              slide.appendChild(oi);
              if (scene.cta) {
                var oc = document.createElement("div");
                oc.className = "cta";
                oc.textContent = scene.cta;
                slide.appendChild(oc);
              }
              break;
          }

          root.appendChild(slide);

          // Fade in → hold → fade out
          var fd = Math.min(fadeDur, dur * 0.15);
          tl.set(slide, { opacity: 0 }, start);
          tl.to(slide, { opacity: 1, duration: fd, ease: "power1.in" }, start);
          tl.set(slide, { opacity: 1 }, start + fd);
          tl.to(slide, { opacity: 0, duration: fd, ease: "power1.out" }, start + dur - fd);
        });

        window.__timelines = window.__timelines || {};
        window.__timelines["main"] = tl;
      })();
    </script>
  </body>
</html>
